# S3バケット名（必須）
S3_BUCKET_NAME=your-bucket-name

# AWSリージョン（デフォルト: ap-northeast-1）
AWS_REGION=ap-northeast-1

# サーバーのポート番号（デフォルト: 3000）
PORT=3000

# -----------------------------------------------
# Cognito設定（Phase 2で追加 - 必須）
# AWSコンソール > Cognito > ユーザープール で確認できる
# -----------------------------------------------
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------
# DynamoDB設定（Phase 3で追加 - 必須）
# AWSコンソール > DynamoDB > テーブル で確認できる
# -----------------------------------------------
DYNAMODB_TABLE_NAME=xxxxxxxxxxxxxxxxxx

# -----------------------------------------------
# Bedrock設定（Phase 5で追加 - 必須）
# Amazon Nova Micro は us-east-1 のみ提供のため、Bedrockだけ別リージョンを使用する
# -----------------------------------------------
BEDROCK_REGION=us-east-1

# -----------------------------------------------
# ローカル開発時のみ使用（EC2では不要）
# EC2ではIAMロールが自動的に認証情報を提供するため不要。
# ローカルでは aws configure で設定するか、以下に直接記述する。
# -----------------------------------------------
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
